# Docker Compose settings
POSTGRES_PASSWORD=change_me_in_production

# Domain for Caddy HTTPS (used in Caddyfile)
DOMAIN=localhost

# See apps/backend/.env.example for backend configuration

# Quick start (dev):
# 1. cp apps/backend/.env.example apps/backend/.env
# 2. npm install
# 3. npm run dev:db          (starts PostgreSQL in Docker)
# 4. npx prisma migrate deploy --schema=apps/backend/prisma/schema.prisma
# 5. npx prisma generate --schema=apps/backend/prisma/schema.prisma
# 6. npm run dev:backend     (terminal 1)
# 7. npm run dev:miniapp     (terminal 2)
#
# Production:
# 1. Set DOMAIN=yourdomain.ru in .env
# 2. Set POSTGRES_PASSWORD in .env
# 3. Configure apps/backend/.env (NODE_ENV=production, JWT_SECRET, BOT_TOKEN, MINIAPP_URL)
# 4. docker compose up -d --build
