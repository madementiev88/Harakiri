# See apps/backend/.env.example for backend configuration
# See apps/backend/.env.production.example for production setup

# Quick start (dev mode with mock data):
# 1. cp apps/backend/.env.example apps/backend/.env
# 2. npm install
# 3. npx prisma generate --schema=apps/backend/prisma/schema.prisma
# 4. npx prisma db push --schema=apps/backend/prisma/schema.prisma
# 5. npm run dev:backend (terminal 1)
# 6. npm run dev:miniapp (terminal 2)
