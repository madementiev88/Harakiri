# Telegram Bot
BOT_TOKEN=your_telegram_bot_token

# YCLIENTS API (leave empty for mock data)
YCLIENTS_PARTNER_TOKEN=
YCLIENTS_USER_TOKEN=
YCLIENTS_SALON_ID=

# Database (auto-set by docker-compose, override for local dev)
DATABASE_URL=postgresql://harakiri:harakiri@localhost:5432/harakiri

# Timezone
TZ=Asia/Yekaterinburg

# Auth — CHANGE IN PRODUCTION! (min 32 chars)
JWT_SECRET=dev-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=24h

# Server
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS) — set to your domain in production
MINIAPP_URL=http://localhost:5173
