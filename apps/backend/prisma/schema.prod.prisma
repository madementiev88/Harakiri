generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  telegramId       BigInt       @id @map("telegram_id")
  firstName        String       @map("first_name") @db.VarChar(100)
  lastName         String?      @map("last_name") @db.VarChar(100)
  phone            String?      @db.VarChar(20)
  yclientsClientId Int?         @map("yclients_client_id")
  pdConsent        Boolean      @default(false) @map("pd_consent")
  pdConsentDate    DateTime?    @map("pd_consent_date") @db.Timestamptz()
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  lastVisit        DateTime?    @map("last_visit") @db.Timestamptz()
  bookings         BookingLog[]

  @@map("users")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

model BookingLog {
  id               String        @id @default(uuid()) @db.Uuid
  telegramId       BigInt        @map("telegram_id")
  yclientsRecordId Int?          @map("yclients_record_id")
  masterId         Int           @map("master_id")
  services         Json          @db.JsonB
  bookingDate      DateTime      @map("booking_date") @db.Date
  bookingTime      String        @map("booking_time") @db.VarChar(5)
  status           BookingStatus @default(pending)
  totalPrice       Int           @map("total_price")
  totalDuration    Int           @map("total_duration")
  reminder24hSent  Boolean       @default(false) @map("reminder_24h_sent")
  reminder2hSent   Boolean       @default(false) @map("reminder_2h_sent")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  user             User          @relation(fields: [telegramId], references: [telegramId])

  @@map("bookings_log")
}
